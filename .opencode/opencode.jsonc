{
  "$schema": "https://opencode.ai/schema.json",
  "version": "1.0",
  "project": {
    "name": "NOX",
    "description": "Industrial-grade full-stack e-commerce platform with Next.js 16, Prisma 6, PostgreSQL, Tailwind CSS 4"
  },
  "agents": {
    "mode": "auto",
    "defaultModel": "deepseek-v4-flash-free",
    "systemPromptFiles": ["AGENTS.md", "ARCHITECTURE.md"]
  },
  "skills": {
    "autoDetect": true,
    "directory": ".opencode/skills"
  },
  "rules": [
    {
      "pattern": "prisma/schema.prisma",
      "instructions": "Run `npm run db:push` after schema changes. Create migration with `npm run db:migrate` for production."
    },
    {
      "pattern": "src/app/api/**/*.ts",
      "instructions": "All API routes must use try-catch and return { data } or { error } JSON."
    },
    {
      "pattern": "src/**/*.tsx",
      "instructions": "Use cn() for className merging. Follow existing component patterns."
    }
  ]
}
